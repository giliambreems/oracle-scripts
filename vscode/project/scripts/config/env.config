#!/bin/bash

###
# Configuration notes:
#
# All necessary applications, tools and equipment are available in the generic git repository and will be updated from there.
#   The generic repository needs to have the same parent folder as this project's repository folder!
###
unset ORACLE_HOME  # make sure global system variables are unset during this session to prevent loading old libraries

BASE_DIR=`pwd`
TOOLS_REPOSITORY_NAME=generic  # Name of the git repository
TOOLS_REPOSITORY_LOCATION="${BASE_DIR}/../${TOOLS_REPOSITORY_NAME}";
GRAALVM_LOCATION="${TOOLS_REPOSITORY_LOCATION}/graalvm";
INSTCL_LOCATION="${TOOLS_REPOSITORY_LOCATION}/instantclient";
SQLCL_LOCATION="${TOOLS_REPOSITORY_LOCATION}/sqlcl";
WALLET_LOCATION="${TOOLS_REPOSITORY_LOCATION}/wallet";

###
# This method requires the installation of the generic repository, which contains all necessary tools and equipment
###
if [ ! -d "${TOOLS_REPOSITORY_LOCATION}" ] ; then
  echo ""
  echo "ERROR: Cannot find shared tools repository $(cygpath -w "${TOOLS_REPOSITORY_LOCATION}")";
  echo ""
  echo "    Please make a clone of the repository \"git clone git@git.mindef.nl:DNA2/${TOOLS_REPOSITORY_NAME}.git\" at $(cygpath -w "..")";
  echo ""
  exit 0;
fi;

if [ ! -d "${GRAALVM_LOCATION}" ] || [ ! -f "${GRAALVM_LOCATION}/bin/java.exe" ] ||
   [ ! -d "${INSTCL_LOCATION}" ] || [ ! -f "${INSTCL_LOCATION}/sqlplus.exe" ] ||
   [ ! -d "${SQLCL_LOCATION}" ] || [ ! -f "${SQLCL_LOCATION}/bin/sql.exe" ] ||
   [[ ${ORA_WALLET_AUTH} == true && ( ! -d "${WALLET_LOCATION}" || ! -f "${WALLET_LOCATION}/bin/mkstore.sh" || ! -f "${WALLET_LOCATION}/bin/orapki.sh" ) ]] ;
then
  echo ""
  echo "ERROR: Cannot find necessary tools inside $(cygpath -w "${TOOLS_REPOSITORY_LOCATION}")";
  echo ""
  echo "    Please verify correct installation of git repository ${TOOLS_REPOSITORY_NAME} or make a new clone of the repository \"git clone git@git.mindef.nl:DNA2/${TOOLS_REPOSITORY_NAME}.git\" at $(cygpath -w "..")";
  echo ""
  exit 0;
fi;

if [ ${ORA_WALLET_AUTH} == true ] && [ ! -d "${WALLET_LOCATION}/$(whoami)" ] ; then
  echo ""
  echo "ERROR: Cannot find Oracle Wallet confisguration folder $(cygpath -w "${WALLET_LOCATION}/$(whoami)")";
  echo ""
  echo "    Please create a personal Oracle Wallet and add the required credentials. For more information, see $(cygpath -w "${WALLET_LOCATION}/bin/examples.readme")";
  echo ""
  exit 0;
fi
###
# End checks
###

###
# Set global variables JAVA_HOME, ORACLE_HOME, TNS_ADMIN and PATH
###
JAVA_HOME=${GRAALVM_LOCATION}  # Add GraalVM to support Javascript with SQLcl 22.1 and higher
SQLCL_HOME=${SQLCL_LOCATION}

export ORACLE_HOME=${INSTCL_LOCATION}
export TNS_ADMIN=${TOOLS_REPOSITORY_LOCATION}/network/admin

PATH=${JAVA_HOME}/bin:${SQLCL_HOME}/bin:${ORACLE_HOME}:${PATH}
